{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Dave",
  "version": "0.1.0",
  "identifier": "com.bochen.dave",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "",
        "width": 820,
        "height": 880,
        "minWidth": 520,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "transparent": false,
        "decorations": true,
        "center": true,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/icon.ico"
    ],
    "shortDescription": "A small, specific presence that lives in this machine.",
    "longDescription": "Dave — a locally-hosted companion. Requires llama-server at C:\\llama.cpp and a GGUF model in C:\\models.",
    "windows": {
      "webviewInstallMode": { "type": "downloadBootstrapper" }
    }
  }
}
